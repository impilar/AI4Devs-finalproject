# Copy to src/infra/.env for Docker Compose, or project root for local dev
DATABASE_URL=postgresql://okc:okc@localhost:5432/okc

# Dev ports (npm run dev in backend/frontend, or Docker Compose full stack)
PORT=3000
CORS_ORIGIN=http://localhost:5173
VITE_API_URL=http://localhost:3000/api/v1
VITE_DEV_PORT=5173
VITE_API_PROXY_TARGET=http://localhost:3000

# E2E ports (Playwright only — see tests/e2e/config/ports.ts)
# E2E_BACKEND_PORT=3100
# E2E_FRONTEND_PORT=5174

NODE_ENV=development
